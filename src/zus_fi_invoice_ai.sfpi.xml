   <cls:CL_FP_CODING id="o5">
    <CL_FP_INTERFACE_DATA_CHANGED classVersion="1">
     <INTERFACE_DATA href="#o1"/>
    </CL_FP_INTERFACE_DATA_CHANGED>
    <CL_FP_CODING classVersion="1">
     <INPUT_PARAMETERS/>
     <OUTPUT_PARAMETERS>
      <FPPARAMETER>GV_EMAIL</FPPARAMETER>
      <FPPARAMETER>GS_ADRC_SP</FPPARAMETER>
      <FPPARAMETER>GS_ADRC</FPPARAMETER>
      <FPPARAMETER>GV_COMP_LOGO</FPPARAMETER>
     </OUTPUT_PARAMETERS>
     <INITIALIZATION>
      <FPCLINE>****Data Declaration****</FPCLINE>
      <FPCLINE>DATA : WA_T247 TYPE T247,</FPCLINE>
      <FPCLINE>       DUE_DATE TYPE BUDAT.</FPCLINE>
      <FPCLINE/>
      <FPCLINE/>
      <FPCLINE>*****Fetching logo****</FPCLINE>
      <FPCLINE>CALL METHOD cl_ssf_xsf_utilities=&gt;get_bds_graphic_as_bmp</FPCLINE>
      <FPCLINE>  EXPORTING</FPCLINE>
      <FPCLINE>    p_object       = &apos;GRAPHICS&apos;</FPCLINE>
      <FPCLINE>    p_name         = &apos;LOGO_FINAL&apos;</FPCLINE>
      <FPCLINE>    p_id           = &apos;BMAP&apos;</FPCLINE>
      <FPCLINE>    p_btype        = &apos;BCOL&apos;</FPCLINE>
      <FPCLINE>  RECEIVING</FPCLINE>
      <FPCLINE>    p_bmp          = gv_comp_logo</FPCLINE>
      <FPCLINE>  EXCEPTIONS</FPCLINE>
      <FPCLINE>    not_found      = 1</FPCLINE>
      <FPCLINE>    internal_error = 2</FPCLINE>
      <FPCLINE>    others         = 3</FPCLINE>
      <FPCLINE>        .</FPCLINE>
      <FPCLINE>IF sy-subrc &lt;&gt; 0.</FPCLINE>
      <FPCLINE>* Implement suitable error handling here</FPCLINE>
      <FPCLINE>ENDIF.</FPCLINE>
      <FPCLINE/>
      <FPCLINE>*****address Details</FPCLINE>
      <FPCLINE>SELECT SINGLE * FROM T001W INTO @data(WA_T001W)</FPCLINE>
      <FPCLINE>  WHERE WERKS = &apos;US01&apos;.</FPCLINE>
      <FPCLINE/>
      <FPCLINE>SELECT SINGLE * FROM ADRC INTO GS_ADRC</FPCLINE>
      <FPCLINE>  WHERE ADDRNUMBER = WA_T001W-ADRNR.</FPCLINE>
      <FPCLINE>*****Ship to Address****</FPCLINE>
      <FPCLINE>  SELECT SINGLE * FROM kna1 INTO @DATA(wa_kna1)</FPCLINE>
      <FPCLINE>  WHERE kunnr = @wa_bseg-kunnr.</FPCLINE>
      <FPCLINE/>
      <FPCLINE>SELECT SINGLE * FROM adrc INTO gs_adrc_sp</FPCLINE>
      <FPCLINE>  WHERE ADDRNUMBER = WA_kna1-ADRNR.</FPCLINE>
      <FPCLINE/>
      <FPCLINE>SELECT ADDRNUMBER,</FPCLINE>
      <FPCLINE>       CONSNUMBER,</FPCLINE>
      <FPCLINE>       SMTP_ADDR  FROM adr6 INTO TABLE @DATA(IT_EMAIL)</FPCLINE>
      <FPCLINE>       WHERE ADDRNUMBER = @WA_kna1-ADRNR.</FPCLINE>
      <FPCLINE>SORT IT_EMAIL by CONSNUMBER.</FPCLINE>
      <FPCLINE>LOOP AT IT_EMAIL INTO DATA(WA_EMAIL).</FPCLINE>
      <FPCLINE>CONCATENATE gv_email WA_EMAIL-smtp_addr &apos;,&apos;  INTO gv_email SEPARATED BY Space.</FPCLINE>
      <FPCLINE>clear : wa_email.</FPCLINE>
      <FPCLINE>ENDLOOP.</FPCLINE>
      <FPCLINE>******Invoice Details**********</FPCLINE>
      <FPCLINE>GV_INV_NO = WA_BSEG-BELNR.</FPCLINE>
      <FPCLINE>SELECT SINGLE * FROM t052 INTO @DATA(wa_t052)</FPCLINE>
      <FPCLINE>  WHERE ZTERM = @wa_bseg-ZTERM.</FPCLINE>
      <FPCLINE/>
      <FPCLINE>SELECT SINGLE * FROM bkpf INTO @DATA(wa_bkpf)</FPCLINE>
      <FPCLINE>   WHERE belnr = @wa_bseg-belnr</FPCLINE>
      <FPCLINE>    AND  gjahr = @wa_bseg-gjahr</FPCLINE>
      <FPCLINE>    AND  bukrs = @wa_bseg-bukrs.</FPCLINE>
      <FPCLINE/>
      <FPCLINE>DATA :day TYPE i.</FPCLINE>
      <FPCLINE>IF wa_t052-ZPRZ1 IS NOT INITIAL.</FPCLINE>
      <FPCLINE>  day = wa_t052-ZTAG2.</FPCLINE>
      <FPCLINE>ELSE.</FPCLINE>
      <FPCLINE>  day = wa_t052-ZTAG1.</FPCLINE>
      <FPCLINE>ENDIF.</FPCLINE>
      <FPCLINE>DUE_DATE = wa_bkpf-budat + Day.</FPCLINE>
      <FPCLINE/>
      <FPCLINE/>
      <FPCLINE>CLEAR WA_T247.</FPCLINE>
      <FPCLINE>CALL FUNCTION &apos;IDWT_READ_MONTH_TEXT&apos;</FPCLINE>
      <FPCLINE>  EXPORTING</FPCLINE>
      <FPCLINE>    langu         = sy-langu</FPCLINE>
      <FPCLINE>    month         = DUE_DATE+4(2)</FPCLINE>
      <FPCLINE> IMPORTING</FPCLINE>
      <FPCLINE>   T247          = WA_T247</FPCLINE>
      <FPCLINE>          .</FPCLINE>
      <FPCLINE/>
      <FPCLINE>TRANSLATE wa_t247-ktx+1(2) TO LOWER CASE.</FPCLINE>
      <FPCLINE>CONCATENATE  wa_t247-ktx DUE_DATE+6(2) DUE_DATE+0(4)</FPCLINE>
      <FPCLINE>                INTO GV_DUE_DATE SEPARATED BY &apos;.&apos;.</FPCLINE>
      <FPCLINE/>
      <FPCLINE>CLEAR WA_T247.</FPCLINE>
      <FPCLINE>CALL FUNCTION &apos;IDWT_READ_MONTH_TEXT&apos;</FPCLINE>
      <FPCLINE>  EXPORTING</FPCLINE>
      <FPCLINE>    langu         = sy-langu</FPCLINE>
      <FPCLINE>    month         = wa_bkpf-budat+4(2)</FPCLINE>
      <FPCLINE> IMPORTING</FPCLINE>
      <FPCLINE>   T247          = WA_T247</FPCLINE>
      <FPCLINE>          .</FPCLINE>
      <FPCLINE>TRANSLATE wa_t247-ktx+1(2) TO LOWER CASE.</FPCLINE>
      <FPCLINE>CONCATENATE  wa_t247-ktx wa_bkpf-budat+6(2) wa_bkpf-budat+0(4)</FPCLINE>
      <FPCLINE>                INTO GV_INV_DATE SEPARATED BY &apos;.&apos;.</FPCLINE>
      <FPCLINE/>
      <FPCLINE/>
      <FPCLINE>*******Supplier Details****</FPCLINE>
      <FPCLINE>GV_CUSTOMER = WA_BSEG-KUNNR.</FPCLINE>
      <FPCLINE>GV_REF      = WA_BKPF-XBLNR.</FPCLINE>
      <FPCLINE>SELECT SINGLE zterm FROM bseg INTO @DATA(lv_zterm)</FPCLINE>
      <FPCLINE>  WHERE  belnr = @wa_bseg-belnr</FPCLINE>
      <FPCLINE>    AND  GJAHR = @wa_bseg-gjahr</FPCLINE>
      <FPCLINE>    AND  bukrs = @wa_bseg-bukrs</FPCLINE>
      <FPCLINE>    AND  shkzg = &apos;S&apos;.</FPCLINE>
      <FPCLINE/>
      <FPCLINE>SELECT SINGLE text1 FROM t052u INTO GV_ZTERM</FPCLINE>
      <FPCLINE>   WHERE  spras = &apos;E&apos;</FPCLINE>
      <FPCLINE>     AND zterm = lv_zterm.</FPCLINE>
      <FPCLINE>******Main Table*******</FPCLINE>
      <FPCLINE>SELECT bukrs</FPCLINE>
      <FPCLINE>       belnr</FPCLINE>
      <FPCLINE>       GJAHR</FPCLINE>
      <FPCLINE>       BUZEI</FPCLINE>
      <FPCLINE>       BSCHL</FPCLINE>
      <FPCLINE>       KOART</FPCLINE>
      <FPCLINE>       SHKZG</FPCLINE>
      <FPCLINE>       DMBTR</FPCLINE>
      <FPCLINE>       SGTXT</FPCLINE>
      <FPCLINE>       HKONT</FPCLINE>
      <FPCLINE>       KUNNR</FPCLINE>
      <FPCLINE>       ZFBDT</FPCLINE>
      <FPCLINE>       ZTERM</FPCLINE>
      <FPCLINE>       TXGRP FROM bseg INTO TABLE gt_bseg</FPCLINE>
      <FPCLINE>       WHERE belnr = wa_bseg-belnr</FPCLINE>
      <FPCLINE>*          AND TXGRP = &apos; &apos;</FPCLINE>
      <FPCLINE>*         AND shkzg = &apos;H&apos;</FPCLINE>
      <FPCLINE>         AND KOART NE &apos;D&apos;</FPCLINE>
      <FPCLINE>         AND BUKRS = &apos;US00&apos;</FPCLINE>
      <FPCLINE>         AND GJAHR = wa_bseg-GJAHR.</FPCLINE>
      <FPCLINE>BREAK DVBASIS.</FPCLINE>
      <FPCLINE>loop at gt_bseg into gs_bseg.</FPCLINE>
      <FPCLINE> IF gs_bseg-SHKZG = &apos;S&apos;.</FPCLINE>
      <FPCLINE>  gv_total = gv_total + gs_bseg-dmbtr.</FPCLINE>
      <FPCLINE>ENDIF.</FPCLINE>
      <FPCLINE>IF gs_bseg-SHKZG = &apos;H&apos;..</FPCLINE>
      <FPCLINE>  gv_total = gv_total - gs_bseg-dmbtr.</FPCLINE>
      <FPCLINE>ENDIF.</FPCLINE>
      <FPCLINE/>
      <FPCLINE>IF gs_bseg-SHKZG = &apos;S&apos;.</FPCLINE>
      <FPCLINE>gs_bseg-dmbtr =  gs_bseg-dmbtr * -1.</FPCLINE>
      <FPCLINE>ENDIF.</FPCLINE>
      <FPCLINE>gs_bseg-amt = gs_bseg-dmbtr.</FPCLINE>
      <FPCLINE>CONCATENATE &apos;$&apos; gs_bseg-amt INTO gs_bseg-amt.</FPCLINE>
      <FPCLINE>modify gt_bseg FROM gs_bseg TRANSPORTING dmbtr amt.</FPCLINE>
      <FPCLINE>  clear : gs_bseg.</FPCLINE>
      <FPCLINE>endloop.</FPCLINE>
      <FPCLINE>if gv_total &lt; 0.</FPCLINE>
      <FPCLINE>  gv_total = gv_total * -1.</FPCLINE>
      <FPCLINE>endif.</FPCLINE>
      <FPCLINE>****Remark*****</FPCLINE>
      <FPCLINE>SELECT SINGLE sgtxt INTO gv_remark FROM bseg</FPCLINE>
      <FPCLINE>    WHERE belnr = wa_bseg-belnr</FPCLINE>
      <FPCLINE>     AND  shkzg = &apos;S&apos;</FPCLINE>
      <FPCLINE>     AND  gjahr = wa_bseg-gjahr</FPCLINE>
      <FPCLINE>     AND  bukrs = &apos;US00&apos;.</FPCLINE>
     </INITIALIZATION>
     <FORMS/>
    </CL_FP_CODING>
   </cls:CL_FP_CODING>
