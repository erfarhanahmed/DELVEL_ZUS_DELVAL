*************Bill-to Address****************
CLEAR wa_adr.
READ TABLE IT_ADR INTO WA_ADR WITH KEY PARTN_ROLE = 'AG'.

IF SY-SUBRC = 0.
SELECT SINGLE * FROM ADRC INTO WA_BILTO
  WHERE ADDRNUMBER = WA_ADR-ADDR_NO.
ENDIF.

SELECT ADDRNUMBER
       CONSNUMBER
       SMTP_ADDR  FROM adr6 INTO TABLE IT_BEMAIL
       WHERE ADDRNUMBER = WA_ADR-ADDR_NO.
SORT IT_BEMAIL by CONSNUMBER.
LOOP AT IT_BEMAIL INTO WA_BEMAIL.
CONCATENATE gv_bemail WA_BEMAIL-smtp_addr ','  INTO gv_bemail SEPARATED BY Space.
ENDLOOP.

*************Ship-to Address****************
CLEAR wa_adr.
READ TABLE IT_ADR INTO WA_ADR WITH KEY PARTN_ROLE = 'WE'.

IF SY-SUBRC = 0.
SELECT SINGLE * FROM ADRC INTO WA_SHIPTO
