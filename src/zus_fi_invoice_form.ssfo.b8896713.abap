

SELECT SINGLE * FROM adrc INTO wa_adrc2
  WHERE ADDRNUMBER = WA_kna1-ADRNR.

SELECT ADDRNUMBER
       CONSNUMBER
       SMTP_ADDR  FROM adr6 INTO TABLE IT_EMAIL
       WHERE ADDRNUMBER = WA_kna1-ADRNR.
SORT IT_EMAIL by CONSNUMBER.
LOOP AT IT_EMAIL INTO WA_EMAIL.
CONCATENATE gv_email WA_EMAIL-smtp_addr ','  INTO gv_email SEPARATED BY Space.
ENDLOOP.

















